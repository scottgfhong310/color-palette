# color-palette — 環境變數範本
# 複製成 .env（已 .gitignore，永不進版控）。所有變數皆「選配」——不設也能跑，只是少了 LLM 潤稿。

# 選配：色彩肖像的「LLM 潤稿」（把決定論的一句描述用模型改寫得更漂亮）。
# 未設對應金鑰 → 功能靜默停用（明細裡不出現潤稿鈕）；純核心（color-portrait-lib）仍完全決定論、零相依。

# 選哪一家：anthropic（預設，保持 canon）| openai | ollama
# LLM_PROVIDER=anthropic

# --- Anthropic（LLM_PROVIDER=anthropic 時用）---
# 取得金鑰：https://console.anthropic.com/  （x-api-key）
# ANTHROPIC_API_KEY=sk-ant-...
# 潤稿用的模型（預設 claude-opus-4-8）。短句改寫想省成本可改 claude-haiku-4-5。
# ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI（LLM_PROVIDER=openai 時用）---
# 取得金鑰：https://platform.openai.com/api-keys  （Authorization: Bearer）
# OPENAI_API_KEY=sk-...
# 潤稿用的模型（預設 gpt-4o-mini）。程式用 max_completion_tokens 送上限，
# 故新推理型模型（gpt-5 / o 系列，強制用它）與 gpt-4o/mini/4-turbo/3.5 都通用。
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama（LLM_PROVIDER=ollama 時用）本機、免金鑰 ---
# 需先跑 Ollama（https://ollama.com）並 `ollama pull <模型>`。走其 OpenAI 相容端點 /v1/chat/completions。
# OLLAMA_BASE_URL=http://localhost:11434     # 預設；本機不必設，遠端才改
# OLLAMA_MODEL=llama3.2                       # 預設 llama3.2；用你已 pull 的模型（如 qwen2.5、gemma3…）

# 選配：覆寫預設 port（canon 預設 3000）。
# PORT=3000
